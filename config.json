{
  "style": {
    "theme": "catpuccin-mocha",
    "customThemes": [
      {
        "name": "nord",
        "palette": {
           "bgDark": "#2e3440",
           "bg": "#2e3440",
           "bgLight": "#4c566a",
           "text": "#eceff4",
           "textMuted": "#e5e9f0",
           "textDisabled": "#d8dee9",
           "textDark": "#2e3440",
           "green": "#a3be8c",
           "yellow": "#ebcb8b",
           "red": "#bf616a",
           "accent": "#8fbcbb"
        }
      }
    ]
  },
  "battery": {
    "warningTreshold": 0.25,
    "criticalTreshold": 0.10,
    "urgentTreshold": 0.03,
    "notifier": {
      "warningIntervalSecs": 600,
      "criticalIntervalSecs": 60,
      "urgentIntervalSecs": 20
    }
  },
  "modules": {
    "clock": {
      "format": "ddd dd - hh:mm"
    },
    "bluetooth": {
      "displayMode": "DisplayIconOnly",
      "batteryLevelAsBackground": true,
      "leftClickedCmd": [
        "myshell-launch-bluetooth"
      ],
      "deviceAliases": [
        {
          "pattern": ".*WH-1000XM3",
          "alias": "Sony"
        },
        {
          "pattern": "Stadia.*",
          "alias": "Stadia"
        }
      ]
    },
    "network": {
      "displayMode": "DisplayNone",
      "leftClickedCmd": [
        "myshell-launch-wifi"
      ]
    },
    "wireguard": {
      "displayMode": "DisplayPreferred",
      "displayOnlyActiveConnections": false,
      "displayPattern": "^\\w+",
      "preferredConnections": [
        "de-fra-wg-001"
      ]
    },
    "volume": {
      "displayMode": "DisplayIconOnly",
      "leftClickedCmd": [
        "myshell-launch-or-focus-tui",
        "wiremix"
      ]
    },
    "battery": {
      "displayMode": "DisplayIconOnly",
      "ignoreBluetoothDevices": true,
      "rightClickedCmd": [
        "wleave"
      ]
    },
    "mpris": {
      "displayProgressBar": true,
      "ignoreBrowsers": false,
      "maxDisplayTextWidth": 200
    }
  }
}
