{
  "battery": {
    "warningTreshold": 0.25,
    "criticalTreshold": 0.10,
    "urgentTreshold": 0.03,
    "notifier": {
      "warningIntervalSecs": 600,
      "criticalIntervalSecs": 60,
      "urgentIntervalSecs": 20
    }
  },
  "modules": {
    "clock": {
      "format": "ddd dd - hh:mm"
    },
    "bluetooth": {
      "displayMode": "DisplayIconOnly",
      "batteryLevelAsBackground": true,
      "leftClickedCmd": [
        "myshell-launch-bluetooth"
      ],
      "deviceAliases": [
        {
          "pattern": ".*WH-1000XM3",
          "alias": "Sony"
        },
        {
          "pattern": "Stadia.*",
          "alias": "Stadia"
        }
      ]
    },
    "network": {
      "displayMode": "DisplayNone",
      "leftClickedCmd": [
        "myshell-launch-wifi"
      ]
    },
    "wireguard": {
      "displayMode": "DisplayShortName",
      "shortDisplayModeCharacterCount": 2
    },
    "volume": {
      "displayMode": "DisplayIconOnly",
      "leftClickedCmd": [
        "myshell-launch-or-focus-tui",
        "wiremix"
      ]
    },
    "battery": {
      "displayMode": "DisplayIconOnly",
      "ignoreBluetoothDevices": true,
      "rightClickedCmd": [
        "wleave"
      ]
    }
  }
}
